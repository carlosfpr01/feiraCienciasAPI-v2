# Database Configuration
DB_URL=jdbc:postgresql://db:5432/feira_ciencias
DB_USER=feira_user
DB_PASS=feira_pass
DB_NAME=feira_ciencias
DB_PORT=5432

# JWT Configuration
JWT_PRIVATE_KEY_PATH=/path/to/privateKey.pem
JWT_PUBLIC_KEY_PATH=/path/to/publicKey.pem
JWT_ISSUER=https://feiraciencias.escola.com.br

# Storage (S3 / Supabase)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=feira-ciencias
S3_PUBLIC_URL=http://localhost:4566/feira-ciencias

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8080
QUARKUS_PROFILE=dev
LOG_LEVEL=INFO
CORS_ENABLED=true
CORS_ORIGINS=*

# Docker & LocalStack
LOCALSTACK_PORT=4566

# GitHub Actions - CI
# SONAR_TOKEN=seu_token_sonar

# GitHub Actions - Deploy no servidor (Settings -> Secrets and variables -> Actions)
# Variable: DEPLOY_ENABLED=true
# Secrets:
#   DEPLOY_HOST=IP_ou_hostname_do_servidor
#   DEPLOY_USER=usuario_ssh
#   DEPLOY_SSH_KEY=chave_privada_ssh_completa
#   DEPLOY_GHCR_TOKEN=PAT_com_read_packages (se imagem GHCR for privada)
#   DEPLOY_PATH=/opt/feira-ciencias-api (opcional)
#   DEPLOY_PORT=22 (opcional)
