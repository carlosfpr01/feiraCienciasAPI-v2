# Copie para .env no servidor: cp .env.production.example .env
# Caminho sugerido no servidor: /opt/feira-ciencias-api/.env

# Imagem publicada pelo GitHub Actions (substitua OWNER/REPO e TAG)
APP_IMAGE=ghcr.io/OWNER/REPO:latest

# Exposicao na rede (0.0.0.0 = todas as interfaces)
APP_HOST=0.0.0.0
APP_PORT=8080

# Banco de dados (PostgreSQL interno ao Docker Compose)
DB_NAME=feira_ciencias
DB_USER=feira_user
DB_PASS=altere_esta_senha_forte

# JWT (chaves no classpath da imagem; use caminhos customizados se montar volume)
JWT_PRIVATE_KEY_PATH=privateKey.pem
JWT_PUBLIC_KEY_PATH=publicKey.pem

# CORS para frontends externos
CORS_ENABLED=true
CORS_ORIGINS=*

# Storage S3 / Supabase (obrigatorio em producao)
S3_ENDPOINT=https://seu-projeto.supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_ACCESS_KEY=sua_access_key
S3_SECRET_KEY=sua_secret_key
S3_BUCKET=feira-ciencias
S3_PUBLIC_URL=https://seu-projeto.supabase.co/storage/v1/object/public/feira-ciencias
